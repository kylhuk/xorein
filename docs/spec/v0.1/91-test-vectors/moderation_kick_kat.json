{
  "description": "moderation.kick: moderator kicking a member succeeds; moderator kicking an admin is forbidden",
  "source": "docs/spec/v0.1/50-family-moderation.md §3.2",
  "inputs": {
    "governance_setup": [
      {"server_id": "srv1", "peer_id": "alice", "role": "admin"},
      {"server_id": "srv1", "peer_id": "bob", "role": "moderator"},
      {"server_id": "srv1", "peer_id": "charlie", "role": "member"},
      {"server_id": "srv1", "peer_id": "diana", "role": "admin"}
    ],
    "server_members": {"srv1": ["alice", "bob", "charlie", "diana"]},
    "cases": [
      {
        "label": "moderator kicks member - success",
        "operation": "moderation.kick",
        "advertised_caps": ["cap.moderation", "cap.slow-mode"],
        "payload": {
          "actor_peer_id": "bob",
          "target_peer_id": "charlie",
          "scope_id": "srv1",
          "reason": "spam"
        }
      },
      {
        "label": "moderator kicks admin - forbidden target",
        "operation": "moderation.kick",
        "advertised_caps": ["cap.moderation", "cap.slow-mode"],
        "payload": {
          "actor_peer_id": "bob",
          "target_peer_id": "diana",
          "scope_id": "srv1",
          "reason": "test"
        }
      },
      {
        "label": "member kicks - unauthorized",
        "operation": "moderation.kick",
        "advertised_caps": ["cap.moderation", "cap.slow-mode"],
        "payload": {
          "actor_peer_id": "charlie",
          "target_peer_id": "bob",
          "scope_id": "srv1",
          "reason": "test"
        }
      }
    ]
  },
  "expected_output": {
    "cases": [
      {"accepted": true, "reason": "REDACT"},
      {"error_code": "MODERATION_FORBIDDEN_TARGET"},
      {"error_code": "MODERATION_UNAUTHORIZED"}
    ]
  }
}
