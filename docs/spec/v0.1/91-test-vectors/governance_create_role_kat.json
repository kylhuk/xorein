{
  "description": "governance.create_role: admin creates custom 'vip' role with bitfield 0x1A; reserved bits and duplicates rejected",
  "source": "docs/spec/v0.1/51-family-governance.md §3.4",
  "inputs": {
    "governance_setup": [
      {"server_id": "srv1", "peer_id": "alice", "role": "admin"},
      {"server_id": "srv1", "peer_id": "bob", "role": "member"}
    ],
    "cases": [
      {
        "label": "admin creates vip role with bitfield 0x1A",
        "operation": "governance.create_role",
        "advertised_caps": ["cap.rbac"],
        "payload": {
          "actor_peer_id": "alice",
          "server_id": "srv1",
          "role_name": "vip",
          "permissions_bitfield": 26,
          "policy_version": 0
        }
      },
      {
        "label": "duplicate role name - conflict",
        "operation": "governance.create_role",
        "advertised_caps": ["cap.rbac"],
        "payload": {
          "actor_peer_id": "alice",
          "server_id": "srv1",
          "role_name": "vip",
          "permissions_bitfield": 1,
          "policy_version": 0
        }
      },
      {
        "label": "reserved bits set - invalid bitfield",
        "operation": "governance.create_role",
        "advertised_caps": ["cap.rbac"],
        "payload": {
          "actor_peer_id": "alice",
          "server_id": "srv1",
          "role_name": "bad",
          "permissions_bitfield": 1024,
          "policy_version": 0
        }
      },
      {
        "label": "base role name - protected",
        "operation": "governance.create_role",
        "advertised_caps": ["cap.rbac"],
        "payload": {
          "actor_peer_id": "alice",
          "server_id": "srv1",
          "role_name": "admin",
          "permissions_bitfield": 1,
          "policy_version": 0
        }
      },
      {
        "label": "member cannot create role - unauthorized",
        "operation": "governance.create_role",
        "advertised_caps": ["cap.rbac"],
        "payload": {
          "actor_peer_id": "bob",
          "server_id": "srv1",
          "role_name": "newrole",
          "permissions_bitfield": 1,
          "policy_version": 0
        }
      }
    ]
  },
  "expected_output": {
    "cases": [
      {"accepted": true, "role_name": "vip"},
      {"error_code": "GOVERNANCE_ROLE_CONFLICT"},
      {"error_code": "GOVERNANCE_INVALID_BITFIELD"},
      {"error_code": "GOVERNANCE_BASE_ROLE_PROTECTED"},
      {"error_code": "GOVERNANCE_UNAUTHORIZED"}
    ]
  }
}
