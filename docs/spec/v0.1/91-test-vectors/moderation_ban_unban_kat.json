{
  "description": "moderation.ban and moderation.unban round-trip; moderator cannot ban (requires admin)",
  "source": "docs/spec/v0.1/50-family-moderation.md §3.3 §3.4",
  "inputs": {
    "governance_setup": [
      {"server_id": "srv1", "peer_id": "alice", "role": "admin"},
      {"server_id": "srv1", "peer_id": "bob", "role": "moderator"},
      {"server_id": "srv1", "peer_id": "charlie", "role": "member"}
    ],
    "cases": [
      {
        "label": "admin bans member - success",
        "operation": "moderation.ban",
        "advertised_caps": ["cap.moderation", "cap.slow-mode"],
        "payload": {"actor_peer_id": "alice", "target_peer_id": "charlie", "scope_id": "srv1"}
      },
      {
        "label": "moderator bans - unauthorized",
        "operation": "moderation.ban",
        "advertised_caps": ["cap.moderation", "cap.slow-mode"],
        "payload": {"actor_peer_id": "bob", "target_peer_id": "charlie", "scope_id": "srv1"}
      },
      {
        "label": "admin unbans - success",
        "operation": "moderation.unban",
        "advertised_caps": ["cap.moderation", "cap.slow-mode"],
        "payload": {"actor_peer_id": "alice", "target_peer_id": "charlie", "scope_id": "srv1"}
      }
    ]
  },
  "expected_output": {
    "cases": [
      {"accepted": true, "reason": "BAN"},
      {"error_code": "MODERATION_UNAUTHORIZED"},
      {"accepted": true}
    ]
  }
}
