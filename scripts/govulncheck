#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$ROOT_DIR/.cache/xorein-tools/bin"
if [[ ! -x "$BIN_DIR/govulncheck" ]]; then
	mkdir -p "$BIN_DIR"
	GOBIN="$BIN_DIR" go install golang.org/x/vuln/cmd/govulncheck@v1.1.4
fi

exec "$BIN_DIR/govulncheck" "$@"
