{
  "description": "voice.ice: three trickle ICE candidates followed by voice.ice_complete marks gathering done",
  "source": "docs/spec/v0.1/52-family-voice.md §3.4",
  "inputs": {
    "mediashield_peer_keys": {"s1": {"peer-p1": "AAECBAUGB", "peer-p2": "AQIDBA=="}},
    "session_setup": [
      {"session_id": "s1", "peer_id": "peer-p1", "codec": "opus"},
      {"session_id": "s1", "peer_id": "peer-p2", "codec": "opus"}
    ],
    "cases": [
      {
        "label": "ICE candidate 1",
        "operation": "voice.ice",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p1",
          "sequence": 1,
          "candidate": "candidate:1 1 UDP 2130706431 192.168.1.10 54400 typ host"
        }
      },
      {
        "label": "ICE candidate 2",
        "operation": "voice.ice",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p1",
          "sequence": 2,
          "candidate": "candidate:2 1 UDP 1694498815 203.0.113.5 54400 typ srflx raddr 192.168.1.10 rport 54400"
        }
      },
      {
        "label": "ICE candidate 3",
        "operation": "voice.ice",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p1",
          "sequence": 3,
          "candidate": "candidate:3 1 TCP 1518280447 192.168.1.10 9 typ host tcptype active"
        }
      },
      {
        "label": "ICE gathering complete",
        "operation": "voice.ice_complete",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p1",
          "sequence": 4
        }
      }
    ]
  },
  "expected_output": {
    "cases": [
      {"ok": true},
      {"ok": true},
      {"ok": true},
      {"ok": true, "gathering_complete": true}
    ]
  }
}
