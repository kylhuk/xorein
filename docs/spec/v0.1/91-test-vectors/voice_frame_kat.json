{
  "description": "voice.frame: valid SFrame ciphertext succeeds; replayed counter is rejected; frame exceeding 65535 bytes rejected with VOICE_FRAME_TOO_LARGE",
  "source": "docs/spec/v0.1/52-family-voice.md §3.2",
  "inputs": {
    "mediashield_peer_keys": {"s1": {"peer-p1": "AAECBAUGB"}},
    "session_setup": [
      {"session_id": "s1", "peer_id": "peer-p1", "codec": "opus"}
    ],
    "cases": [
      {
        "label": "valid frame counter=1 → accepted",
        "operation": "voice.frame",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "sender_id": "peer-p1",
          "counter": 1,
          "ciphertext": "AQIDBA=="
        }
      },
      {
        "label": "valid frame counter=2 → accepted",
        "operation": "voice.frame",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "sender_id": "peer-p1",
          "counter": 2,
          "ciphertext": "BQYHCA=="
        }
      },
      {
        "label": "replay counter=1 → rejected",
        "operation": "voice.frame",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "sender_id": "peer-p1",
          "counter": 1,
          "ciphertext": "AQIDBA=="
        }
      },
      {
        "label": "oversized frame → VOICE_FRAME_TOO_LARGE",
        "operation": "voice.frame",
        "advertised_caps": ["cap.voice"],
        "synthetic": "large_frame",
        "payload": {
          "session_id": "s1",
          "sender_id": "peer-p1",
          "counter": 3
        }
      }
    ]
  },
  "expected_output": {
    "cases": [
      {"ok": true},
      {"ok": true},
      {"error_code": "REPLAY_DETECTED"},
      {"error_code": "VOICE_FRAME_TOO_LARGE"}
    ]
  }
}
