#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$ROOT_DIR/.cache/xorein-tools/bin"
if [[ ! -x "$BIN_DIR/gosec" ]]; then
	mkdir -p "$BIN_DIR"
	GOBIN="$BIN_DIR" go install github.com/securego/gosec/v2/cmd/gosec@v2.22.2
fi

exec "$BIN_DIR/gosec" "$@"
