#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$ROOT_DIR/.cache/xorein-tools/bin"
if [[ ! -x "$BIN_DIR/trivy" ]]; then
	mkdir -p "$BIN_DIR"
	GOBIN="$BIN_DIR" go install github.com/aquasecurity/trivy/cmd/trivy@v0.61.0
fi

exec "$BIN_DIR/trivy" "$@"
