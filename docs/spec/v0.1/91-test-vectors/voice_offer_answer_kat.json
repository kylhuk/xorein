{
  "description": "voice.offer with Opus in SDP succeeds; voice.offer without Opus → VOICE_CODEC_UNSUPPORTED; voice.answer pairs to latest offer",
  "source": "docs/spec/v0.1/52-family-voice.md §3.3",
  "inputs": {
    "mediashield_peer_keys": {"s1": {"peer-p1": "AAECBAUGB", "peer-p2": "AQIDBA=="}},
    "session_setup": [
      {"session_id": "s1", "peer_id": "peer-p1", "codec": "opus"},
      {"session_id": "s1", "peer_id": "peer-p2", "codec": "opus"}
    ],
    "cases": [
      {
        "label": "offer with Opus SDP → accepted",
        "operation": "voice.offer",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p1",
          "sequence": 1,
          "sdp": "v=0\r\no=- 0 0 IN IP4 127.0.0.1\r\ns=-\r\nt=0 0\r\nm=audio 9 UDP/TLS/RTP/SAVPF 111\r\na=rtpmap:111 opus/48000/2\r\n"
        }
      },
      {
        "label": "answer pairs to offer",
        "operation": "voice.answer",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p2",
          "sequence": 1,
          "sdp": "v=0\r\no=- 1 1 IN IP4 127.0.0.1\r\ns=-\r\nt=0 0\r\nm=audio 9 UDP/TLS/RTP/SAVPF 111\r\na=rtpmap:111 opus/48000/2\r\n"
        }
      },
      {
        "label": "offer without Opus SDP → VOICE_CODEC_UNSUPPORTED",
        "operation": "voice.offer",
        "advertised_caps": ["cap.voice"],
        "payload": {
          "session_id": "s1",
          "peer_id": "peer-p1",
          "sequence": 2,
          "sdp": "v=0\r\no=- 2 2 IN IP4 127.0.0.1\r\ns=-\r\nt=0 0\r\nm=audio 9 UDP/TLS/RTP/SAVPF 0\r\na=rtpmap:0 PCMU/8000\r\n"
        }
      }
    ]
  },
  "expected_output": {
    "cases": [
      {"ok": true},
      {"ok": true},
      {"error_code": "VOICE_CODEC_UNSUPPORTED"}
    ]
  }
}
